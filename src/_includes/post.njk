---
layout: base.njk
---
<a href="{{ '/' | url }}" class="back">&lt;- back</a>

<header class="post-header">
  <h1 class="post-title">{{ title }}</h1>
  <time class="post-date" datetime="{{ date | isoDate }}">{{ date | postDate }}</time>
</header>

<article class="post-content">
{{ content | safe }}
</article>

<a href="{{ '/' | url }}" class="back">&lt;- back</a>
